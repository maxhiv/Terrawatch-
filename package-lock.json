import { useFeedStatus } from "../hooks/useFeeds";

const CAT_COLORS = { AIR:"text-amber-400", WATER:"text-blue-400", WEATHER:"text-violet-400", IMAGERY:"text-green-400", SOIL:"text-orange-400", BIO:"text-teal-400" };

export default function Feeds() {
  const { data, isLoading } = useFeedStatus();

  return (
    <div className="p-6 space-y-4">
      <div className="flex items-center justify-between">
        <h1 className="text-2xl font-bold text-white">Data Feeds</h1>
        <div className="flex gap-3 text-sm">
          <span className="text-green-400">{data?.live ?? "—"} live</span>
          <span className="text-red-400">{data?.failing ?? "—"} failing</span>
        </div>
      </div>

      <div className="grid gap-2">
        {isLoading ? (
          [...Array(8)].map((_,i)=><div key={i} className="card h-14 animate-pulse"/>)
        ) : data?.feeds?.map(feed => (
          <div key={feed.id} className="card p-3 flex items-center gap-4">
            <div className={`w-2 h-2 rounded-full flex-shrink-0 ${feed.lastStatus === 200 ? "bg-green-400 shadow-[0_0_6px_#34d399]" : feed.lastStatus ? "bg-red-400" : "bg-slate-600"}`}/>
            <div className="flex-1 min-w-0">
              <div className="flex items-center gap-2">
                <span className={`text-xs font-mono ${CAT_COLORS[feed.category] || "text-slate-400"}`}>{feed.category}</span>
                <span className="text-sm text-slate-200 truncate">{feed.name}</span>
                <span className="text-xs font-mono text-slate-500">{feed.code}</span>
              </div>
            </div>
            {feed.latencyMs && <span className="text-xs text-slate-500 flex-shrink-0">{feed.latencyMs}ms</span>}
            {feed.lastPolledAt && <span className="text-xs text-slate-500 flex-shrink-0">{new Date(feed.lastPolledAt).toLocaleTimeString()}</span>}
          </div>
        ))}
      </div>
    </div>
  );
}
