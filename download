# TERRAWATCH Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# API Keys (get free keys at the URLs below)
# https://airnowapi.org/
AIRNOW_API_KEY=your_key_here

# https://aqs.epa.gov/aqsweb/documents/data_api.html
EPA_AQS_EMAIL=your_email_here
EPA_AQS_KEY=your_key_here

# https://urs.earthdata.nasa.gov/ (for MODIS/HLS/PACE)
NASA_EARTHDATA_USER=your_username
NASA_EARTHDATA_PASS=your_password

# https://ebird.org/api/keygen
EBIRD_API_KEY=your_key_here

# Anthropic (for AI Field Assistant)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=your_key_here

# Vexcel (contact vexceldata.com for evaluation)
VEXCEL_API_KEY=your_key_here

# Frontend
VITE_API_BASE_URL=http://localhost:3001
