{
  "name": "terrawatch",
  "version": "1.0.0",
  "description": "TERRAWATCH — Planetary Environmental Intelligence Platform",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm --workspace @terrawatch/web run dev -- --port 5000 --host 0.0.0.0",
    "dev:server": "node --watch server/index.js",
    "build": "npm --workspace @terrawatch/web run build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "node-cron": "^3.0.3",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "adm-zip": "^0.5.17"
  }
}
