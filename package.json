{
  "name": "terrawatch",
  "version": "1.0.0",
  "description": "TERRAWATCH — Planetary Environmental Intelligence Platform",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm --workspace @terrawatch/web run dev -- --port 5000 --host 0.0.0.0",
    "dev:server": "node --watch apps/api/src/index.js",
    "build": "npm --workspace @terrawatch/web run build",
    "start": "node apps/api/src/index.js"
  },
  "dependencies": {
    "concurrently": "^9.1.2"
  },
  "devDependencies": {
    "adm-zip": "^0.5.17"
  }
}
